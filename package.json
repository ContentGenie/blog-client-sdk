{
  "name": "@contentgenie/blog-client-sdk",
  "version": "1.1.0",
  "description": "TypeScript SDK for consuming Content Genie blog articles on client websites",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "contentgenie",
    "blog",
    "sdk",
    "nextjs",
    "isr",
    "cms"
  ],
  "author": "ContentGenie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ContentGenie/blog-client-sdk.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
}
